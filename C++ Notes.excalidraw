      "updated": 1770655812522,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    char count = 'A';\n    for (int i = 1; i <= n; i++) { //outer loop\n        char count = 'A';\n        for (int j = 1; j <= n - i; j++) {\n//spaces\n            cout << \" \";\n        }\n        for (int j = 1; j <= (2 * i) - 1; j++) {\n            cout << count;\n            if (j < i) {\n                count++;\n            }\n            else {\n                count--;\n            }\n        }\n        cout << endl;\n    }\n\n}",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    char count = 'A';\n    for (int i = 1; i <= n; i++) { //outer loop\n        char count = 'A';\n        for (int j = 1; j <= n - i; j++) { //spaces\n            cout << \" \";\n        }\n        for (int j = 1; j <= (2 * i) - 1; j++) {\n            cout << count;\n            if (j < i) {\n                count++;\n            }\n            else {\n                count--;\n            }\n        }\n        cout << endl;\n    }\n\n}",
      "autoResize": false,
