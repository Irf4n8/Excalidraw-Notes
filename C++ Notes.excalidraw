      "updated": 1771230604854,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    for (int i = 0; i < n; i++) {\n        for (int j = 1; j <= n - i - 1; j++) {\n            cout << \" \";\n        }\n        for (int j = 1; j <= 1; j++) {\n            cout << \"*\";\n        }\n        for (int j = 1; j <= (2 * i) -1; j++) {\n                cout << \" \";\n            }\n        if (i > 0) {\n            for (int j = 1; j <= 1; j++) {\n                cout << \"*\";\n            }\n        }\n        cout << endl;\n    }\n\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    for (int i = 0; i < n; i++) {\n        for (int j = 1; j <= n - i - 1; j++) {\n            cout << \" \";\n        }\n        for (int j = 1; j <= 1; j++) {\n            cout << \"*\";\n        }\n        for (int j = 1; j <= (2 * i) -1; j++) {\n                cout << \" \";\n            }\n        if (i > 0) {\n            for (int j = 1; j <= 1; j++) {\n                cout << \"*\";\n            }\n        }\n        cout << endl;\n    }\n\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
