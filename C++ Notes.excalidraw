      "text": "Conditionals\n#include<iostream>//input an doutput lib\nusing namespace std;\nint main(){\n    int gf_age;\n    std::cin >> gf_age;\n    std::cin >> gf_age;\n    std::cin >> gf_age;\n    std::cout << \"Are they Pedo????\" << std::endl;\n    if(gf_age<13){\n        std::cout << \"Yes Sanjeev is Pedo as per the Records\" << std::endl;\n        \n    }\n    else if(gf_age>=13&&gf_age<19){\n        std::cout << \"Teenage\"<< std::endl;\n    }\n    else {\n        std::cout << \"Adult\" << std::endl;\n    }\n}",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Conditionals\n#include<iostream>//input an doutput lib\nusing namespace std;\nint main(){\n    int gf_age;\n    std::cin >> gf_age;\n    std::cin >> gf_age;\n    std::cin >> gf_age;\n    std::cout << \"Are they Pedo????\" << std::endl;\n    if(gf_age<13){\n        std::cout << \"Yes Sanjeev is Pedo as per the Records\" << std::endl;\n        \n    }\n    else if(gf_age>=13&&gf_age<19){\n        std::cout << \"Teenage\"<< std::endl;\n    }\n    else {\n        std::cout << \"Adult\" << std::endl;\n    }\n}",
