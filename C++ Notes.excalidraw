      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\nvoid upperhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        for (int j = 1; j <= i; j++) {\n            cout << \"*\";\n        }\n        for(int j=1;j<=(n*2)-(2*i);j++){\n            cout<<\" \";\n        }\n        for(int j=1;j<=i;j++){\n            cout<<\"*\";\n        }\n        cout << endl;\n    }\n}\nvoid lowerhalf(int n) {\n    for (int i = 1; i < n; i++) {\n        for (int j = 1; j <= n - i ; j++) {\n            cout << \"*\";\n\n        }\n        for(int j=1;j< (2*i)+1;j++){\n            cout<<\" \";\n        }\n        for(int j=1;j<=n-i;j++){\n            cout<<\"*\";\n        }\n        \n        cout << endl;\n    }\n\n}\nint main() {\n    int n;\n    cin >> n;\n    upperhalf(n);\n    lowerhalf(n);\n\n}",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\nvoid upperhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        for (int j = 1; j <= i; j++) {\n            cout << \"*\";\n        }\n        for(int j=1;j<=(n*2)-(2*i);j++){\n            cout<<\" \";\n        }\n        for(int j=1;j<=i;j++){\n            cout<<\"*\";\n        }\n        cout << endl;\n    }\n}\nvoid lowerhalf(int n) {\n    for (int i = 1; i < n; i++) {\n        for (int j = 1; j <= n - i ; j++) {\n            cout << \"*\";\n\n        }\n        for(int j=1;j< (2*i)+1;j++){\n            cout<<\" \";\n        }\n        for(int j=1;j<=n-i;j++){\n            cout<<\"*\";\n        }\n        \n        cout << endl;\n    }\n\n}\nint main() {\n    int n;\n    cin >> n;\n    upperhalf(n);\n    lowerhalf(n);\n\n}",
      "autoResize": true,
      "lineHeight": 1.25
