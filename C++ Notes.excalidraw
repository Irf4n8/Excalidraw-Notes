      "link": null,
      "locked": false,
      "text": "#include <iostream>\n\nusing namespace std;\n\nint main() {\n    int n;\n    cin >> n;\n\n    for (int i = 1; i <= n; i++) {\n        for (int j = 1; j <= i; j++) {\n            if ((i + j) % 2 == 0)\n                cout << \"1\"<<\" \";\n            else\n                cout << \"0\"<<\" \";\n        }\n        cout << endl;\n    }\n\n    return 0;\n}",
      "fontSize": 36,
      "fontFamily": 5,
