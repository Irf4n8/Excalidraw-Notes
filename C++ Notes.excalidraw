      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    int n;\n    cin >> n;\n\n    for (int i = 0; i < (n + 1) / 2; i++) {\n\n        // spaces\n        for (int j = 0; j < i; j++) {\n            cout << \" \";\n        }\n\n        // stars\n        for (int j = 0; j < n - 2 * i; j++) {\n            cout << \"*\";\n        }\n\n        cout << endl;\n    }\n\n    return 0;\n}",
      "fontSize": 37.37061476890951,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    int n;\n    cin >> n;\n\n    for (int i = 0; i < (n + 1) / 2; i++) {\n\n        // spaces\n        for (int j = 0; j < i; j++) {\n            cout << \" \";\n        }\n\n        // stars\n        for (int j = 0; j < n - 2 * i; j++) {\n            cout << \"*\";\n        }\n\n        cout << endl;\n    }\n\n    return 0;\n}",
      "autoResize": true,
      "lineHeight": 1.25
