      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n        // your code goes here\n        int n;\n        cin>>n;\n        int array[n];\n        for(int i=0;i<n;i++){\n            cin>>array[i];\n        }\n        //printing the reverse the array\n        for(int i=n-1;i>=0;i--){\n            cout<<array[i]<<\" \";\n        }\n        cout<<array[0];\n\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n        // your code goes here\n        int n;\n        cin>>n;\n        int array[n];\n        for(int i=0;i<n;i++){\n            cin>>array[i];\n        }\n        //printing the reverse the array\n        for(int i=n-1;i>=0;i--){\n            cout<<array[i]<<\" \";\n        }\n        cout<<array[0];\n\n}",
