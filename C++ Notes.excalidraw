      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    char end = 'A' + n - 1;\n    for (int i = 0; i < n; i++) { //outer loop\n        char start = end - i ;\n        for (char j = start; j <= end; j++) {\n            cout << j;\n        }\n        cout << endl;\n    }\n\n}",
