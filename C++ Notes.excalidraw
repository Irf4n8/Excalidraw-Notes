      "isDeleted": false,
      "boundElements": [],
      "updated": 1770559708201,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int num;\n    std::cin >> num;\n    for (int i = 0; i < num; i++) {\n        for (int j = 1; j <= num - i; j++) { //run\nn-i times\n            cout << \" \";\n        }\n        for (int j = 1; j <= 2 * i - 1; j++) {\n//1,3,5,7\n            cout << \"*\";\n        }\n        for (int j = 1; j <= num - i; j++) { //run\nn-i times\n            cout << \" \";\n        }\n        cout << endl;\n    }\n}",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int num;\n    std::cin >> num;\n    for (int i = 0; i < num; i++) {\n        for (int j = 1; j <= num - i; j++) { //run n-i times\n            cout << \" \";\n        }\n        for (int j = 1; j <= 2 * i - 1; j++) { //1,3,5,7\n            cout << \"*\";\n        }\n        for (int j = 1; j <= num - i; j++) { //run n-i times\n            cout << \" \";\n        }\n        cout << endl;\n    }\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
