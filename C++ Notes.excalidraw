      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    for (int i = 1; i <= n; i++) {\n        for (int j = 1; j <= n; j++) {\n            \n            if (i == 1 || i == n || j == 1 || j == n) {\n                cout << \"*\";\n            }\n            else{\n                cout<<\" \";\n            }\n        }\n    cout << endl;\n    }\n    \n}",
