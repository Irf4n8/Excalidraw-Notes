      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    for (int i = 1; i <= n; i++) {\n        for (int j = 1; j <= i; j++) {\n            cout << j;\n        }\n        for (int j = 1; j <= 2 * (n - i); j++) {\n            cout << \"0\";\n        }\n        for (int j = i; j >= 1; j--) {\n            cout << j;\n        }\n        cout << endl;\n    }\n\n}",
      "fontSize": 36,
      "fontFamily": 5,
