      "text": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n        // your code goes here\n        int n;\n        cin>>n;\n        int array[n];\n        for(int i=1;i<=n;i++){\n            cin>>array[i];\n        }\n        for(int i=1;i<=n;i++){\n            cout<<array[i]<<\" \";\n        }\n\n}",
      "fontSize": 23.810421155458254,
