      "updated": 1770614419547,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint upperhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        // spaces\n        for (int j = 1; j <= i; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint lowerhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        for (int j = 1; j < n - i; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint main() {\n    int n;\n    cin >> n;\n    upperhalf(n);\n    lowerhalf(n);\n    return 0;\n}",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint upperhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        // spaces\n        for (int j = 1; j <= i; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint lowerhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        for (int j = 1; j < n - i; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint main() {\n    int n;\n    cin >> n;\n    upperhalf(n);\n    lowerhalf(n);\n    return 0;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
