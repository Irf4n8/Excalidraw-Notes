      "updated": 1771308690676,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // Maximum Elements\n    int n; //\n    cin >> n; //\n    int arr[n]; //\n    int prevmax;\n    for (int i = 0; i < n; i++) { //\n        cin >> arr[i]; //\n    }\n    int max = arr[0];\n    for (int i = 1; i < n; i++) {\n        if (arr[i] > max) {\n            prevmax=max;\n            max = arr[i];\n        }\n    }\n    cout << max << \" \" << \"it is the max element\" << '\\n';\n    cout << prevmax << \" \" << \"it is second max element\" << '\\n';\n    return 0;\n\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // Maximum Elements\n    int n; //\n    cin >> n; //\n    int arr[n]; //\n    int prevmax;\n    for (int i = 0; i < n; i++) { //\n        cin >> arr[i]; //\n    }\n    int max = arr[0];\n    for (int i = 1; i < n; i++) {\n        if (arr[i] > max) {\n            prevmax=max;\n            max = arr[i];\n        }\n    }\n    cout << max << \" \" << \"it is the max element\" << '\\n';\n    cout << prevmax << \" \" << \"it is second max element\" << '\\n';\n    return 0;\n\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
