      "text": "#include<iostream>\nusing namespace std;\nint main(){\n    int n;\n    cin>>n;\n    for(int i =1;i<=n;i++){\n        for(int j=1;j<=i;j++){\n            cout<<\"*\";\n        }\n    cout<<endl;\n    }\n}\n    ",
