      "updated": 1770613890253,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint upperhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        // spaces\n        for (int j = 0; j < n - i; j++) {\n            cout << \" \";\n        }\n        // stars\n        for (int j = 0; j < (2 * i) - 1; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint lowerhalf(int n) {\n    for (int i = n - 1; i >= 1; i--) {\n        for (int j = 0; j < n - i; j++) {\n            cout << \" \";\n        }\n        for (int j = 0; j < (2 * i) - 1; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint main() {\n    int n;\n    cin >> n;\n    upperhalf(n);\n    lowerhalf(n);\n    return 0;\n}",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint upperhalf(int n) {\n    for (int i = 1; i <= n; i++) {\n        // spaces\n        for (int j = 0; j < n - i; j++) {\n            cout << \" \";\n        }\n        // stars\n        for (int j = 0; j < (2 * i) - 1; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint lowerhalf(int n) {\n    for (int i = n - 1; i >= 1; i--) {\n        for (int j = 0; j < n - i; j++) {\n            cout << \" \";\n        }\n        for (int j = 0; j < (2 * i) - 1; j++) {\n            cout << \"*\";\n        }\n        cout << endl;\n    }\n    return 0;\n}\n\nint main() {\n    int n;\n    cin >> n;\n    upperhalf(n);\n    lowerhalf(n);\n    return 0;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
