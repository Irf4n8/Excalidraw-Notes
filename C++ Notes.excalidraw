      "text": "#include <bits/stdc++.h>\n\nusing namespace std;\n\nint main() {\n    // your code goes here\n    int n;\n    cin >> n;\n    char count = 'A';\n    for (int i = 1; i <= n; i++) { //outer loop\n        for (int j = 1; j <= i; j++) {\n            cout << count;\n        }\n        count++;\n        cout << endl;\n    }\n\n}",
