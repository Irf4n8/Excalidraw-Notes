      "updated": 1770797648911,
      "link": null,
      "locked": false,
      "text": "🔹 Problem 1\nfor(int i = 0; i < n; i++) {\n  cout << i;\n}\n\n\n👉 Time = ? O (n)\n👉 Space = ?O()\n\n🔹 Problem 2\nfor(int i = 0; i < n; i++) {\n  for(int j = 0; j < n; j++) {\n    cout << i << j;\n  }\n}\n\n\n👉 Time = O(n^2)\n👉 Space = O(1)\n\n🔹 Problem 3\nint arr[n];\nfor(int i = 0; i < n; i++) {\n  arr[i] = i;\n}\n\n\n👉 Time = O(n)\n👉 Space = O(n)//remember\n\n🔹 Problem 4\nwhile(n > 1) {\n  n = n / 2;\n}\n\n\n👉 Time = O(logn)\n👉 Space = O(1)\n\n🔹 Problem 5\nvoid fun(int n) {\n  if(n == 0) return;\n  fun(n - 1);\n}\n\n\n👉 Time = ?\n👉 Space = ?\n\n🔹 Problem 6\nfor(int i = 0; i < n; i++) {\n  for(int j = 1; j < n; j = j *\n2) {\n    cout << i << j;\n  }\n}\n\n\n👉 Time = O(n log n)\n👉 Space = O(1)\n\n🔹 Problem 7\nint sum = 0;\nfor(int i = 0; i < n; i++) {\n  for(int j = i; j < n; j++) {\n    sum++;\n  }\n}\n\n\n👉 Time = ?O(n^2)\n👉 Space = ?O(1)",
      "fontSize": 34.93203143585131,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🔹 Problem 1\nfor(int i = 0; i < n; i++) {\n  cout << i;\n}\n\n\n👉 Time = ? O (n)\n👉 Space = ?O()\n\n🔹 Problem 2\nfor(int i = 0; i < n; i++) {\n  for(int j = 0; j < n; j++) {\n    cout << i << j;\n  }\n}\n\n\n👉 Time = O(n^2)\n👉 Space = O(1)\n\n🔹 Problem 3\nint arr[n];\nfor(int i = 0; i < n; i++) {\n  arr[i] = i;\n}\n\n\n👉 Time = O(n)\n👉 Space = O(n)//remember\n\n🔹 Problem 4\nwhile(n > 1) {\n  n = n / 2;\n}\n\n\n👉 Time = O(logn)\n👉 Space = O(1)\n\n🔹 Problem 5\nvoid fun(int n) {\n  if(n == 0) return;\n  fun(n - 1);\n}\n\n\n👉 Time = ?\n👉 Space = ?\n\n🔹 Problem 6\nfor(int i = 0; i < n; i++) {\n  for(int j = 1; j < n; j = j * 2) {\n    cout << i << j;\n  }\n}\n\n\n👉 Time = O(n log n)\n👉 Space = O(1)\n\n🔹 Problem 7\nint sum = 0;\nfor(int i = 0; i < n; i++) {\n  for(int j = i; j < n; j++) {\n    sum++;\n  }\n}\n\n\n👉 Time = ?O(n^2)\n👉 Space = ?O(1)",
      "autoResize": false,
      "lineHeight": 1.25
    },
