      "versionNonce": 379856010,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457885779,
      "link": null,
      "locked": false,
      "text": "Groups rows that share a value and applies aggregate functions to each group. Used with COUNT, SUM, AVG, etc.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Groups rows that share a value and applies aggregate functions to each group. Used with COUNT, SUM, AVG, etc.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LvpRxsNhQwwKpPhTUO1JC",
      "type": "text",
      "x": -12212.072471514284,
      "y": 10521.906426049334,
      "width": 1108.0598754882817,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bN9",
      "roundness": null,
      "seed": 165558474,
      "version": 215,
      "versionNonce": 1455128982,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457899689,
      "link": null,
      "locked": false,
      "text": "SELECT dept, COUNT(*) AS total, AVG(salary) AS avg_sal\nFROM employees\nGROUP BY dept;\n\n-- HAVING filters grouped results (like WHERE but for\ngroups)\nSELECT dept, AVG(salary) AS avg_sal\nFROM employees\nGROUP BY dept\nHAVING avg_sal > 50000;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT dept, COUNT(*) AS total, AVG(salary) AS avg_sal\nFROM employees\nGROUP BY dept;\n\n-- HAVING filters grouped results (like WHERE but for groups)\nSELECT dept, AVG(salary) AS avg_sal\nFROM employees\nGROUP BY dept\nHAVING avg_sal > 50000;",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ISyadzr1enxowZwUTq2MA",
      "type": "text",
      "x": -10950.808962399702,
      "y": 10597.739759382668,
      "width": 772.1995239257812,
      "height": 90,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
