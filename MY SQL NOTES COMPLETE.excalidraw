      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457789091,
      "link": null,
      "locked": false,
      "text": "CREATE INDEX idx_name ON students(name);\nCREATE INDEX idx_gpa_name ON students(gpa, name); -- composite\n\nSHOW INDEXES FROM students;\nDROP INDEX idx_name ON students;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE INDEX idx_name ON students(name);\nCREATE INDEX idx_gpa_name ON students(gpa, name); -- composite\n\nSHOW INDEXES FROM students;\nDROP INDEX idx_name ON students;",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
