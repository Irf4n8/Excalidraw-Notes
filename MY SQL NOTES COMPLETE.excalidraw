      "updated": 1775457713040,
      "link": null,
      "locked": false,
      "text": "A view is a saved SELECT query that acts like a virtual table. Simplifies complex queries and adds a security layer.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A view is a saved SELECT query that acts like a virtual table. Simplifies complex queries and adds a security layer.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "eILKf18hsBfUyP1nWKR10",
      "type": "text",
      "x": -12187.592044907611,
      "y": 8675.120711763624,
      "width": 1246.7180698939726,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bMx",
      "roundness": null,
      "seed": 1471024854,
      "version": 242,
      "versionNonce": 179785430,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457750611,
      "link": null,
      "locked": false,
      "text": "CREATE VIEW high_gpa_students AS\nSELECT name, gpa FROM students WHERE gpa >= 3.5;\n\nSELECT * FROM high_gpa_students;   -- use like a table\n\nDROP VIEW high_gpa_students;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE VIEW high_gpa_students AS\nSELECT name, gpa FROM students WHERE gpa >= 3.5;\n\nSELECT * FROM high_gpa_students;   -- use like a table\n\nDROP VIEW high_gpa_students;",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "A3J5q80Z5rpJ2-y4cNSZG",
      "type": "text",
      "x": -10845.661581389195,
      "y": 8694.049283192197,
      "width": 1514.735595703125,
      "height": 45,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
