      "boundElements": null,
      "updated": 1775457863248,
      "link": null,
      "locked": false,
      "text": "-- In WHERE\nSELECT name FROM students\nWHERE gpa > (SELECT AVG(gpa) FROM students);\n\n-- In FROM (derived table)\nSELECT avg_data.dept, avg_data.avg_sal\nFROM (SELECT dept, AVG(salary) AS avg_sal\n      FROM employees GROUP BY dept) AS avg_data;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-- In WHERE\nSELECT name FROM students\nWHERE gpa > (SELECT AVG(gpa) FROM students);\n\n-- In FROM (derived table)\nSELECT avg_data.dept, avg_data.avg_sal\nFROM (SELECT dept, AVG(salary) AS avg_sal\n      FROM employees GROUP BY dept) AS avg_data;",
      "autoResize": true,
      "lineHeight": 1.25
    },
