      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457778350,
      "link": null,
      "locked": false,
      "text": "Indexes speed up SELECT queries on large tables by creating a sorted lookup structure. Trade-off: faster reads, slower writes.Indexes speed up SELECT queries on large tables by creating a sorted lookup structure. Trade-off: faster reads, slower writes.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Indexes speed up SELECT queries on large tables by creating a sorted lookup structure. Trade-off: faster reads, slower writes.Indexes speed up SELECT queries on large tables by creating a sorted lookup structure. Trade-off: faster reads, slower writes.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Icw2xciOAKdZsaiYk6quk",
      "type": "text",
      "x": -12181.37586710348,
      "y": 9244.049283192197,
      "width": 1227.599365234375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
