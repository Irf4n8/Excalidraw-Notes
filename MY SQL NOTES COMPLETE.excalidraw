      "seed": 1016723587,
      "version": 5,
      "versionNonce": 1567194989,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775373994724,
      "link": null,
      "locked": false,
      "text": "-- AND: both conditions must be true\nSELECT * FROM students WHERE gpa > 3.0 AND enroll_date > '2024-01-01';\n\n-- OR: at least one condition must be true\nSELECT * FROM students WHERE gpa > 3.5 OR name = 'Arjun';\n\n-- NOT: negates a condition\nSELECT * FROM students WHERE NOT gpa = 0;\nSELECT * FROM students WHERE name NOT IN ('Arjun', 'Priya');",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-- AND: both conditions must be true\nSELECT * FROM students WHERE gpa > 3.0 AND enroll_date > '2024-01-01';\n\n-- OR: at least one condition must be true\nSELECT * FROM students WHERE gpa > 3.5 OR name = 'Arjun';\n\n-- NOT: negates a condition\nSELECT * FROM students WHERE NOT gpa = 0;\nSELECT * FROM students WHERE name NOT IN ('Arjun', 'Priya');",
      "autoResize": true,
      "lineHeight": 1.25
    },
