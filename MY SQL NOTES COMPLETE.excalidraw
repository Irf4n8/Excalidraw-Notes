    {
      "id": "ay7UUBz46DXS8EVOg3Fb5",
      "type": "text",
      "x": -16499.79987815214,
      "y": 11263.06771595335,
      "width": 2747.9995117187495,
      "height": 4500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bL8",
      "roundness": null,
      "seed": 557283693,
      "version": 409,
      "versionNonce": 380866093,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775367264703,
      "link": null,
      "locked": false,
      "text": "UNIQUE\n\nEnsures all values in a column are different. Multiple UNIQUE columns are allowed per table (unlike PRIMARY KEY).\n\nCREATE TABLE users (\n  user_id INT,\n  email   VARCHAR(100) UNIQUE,\n  phone   VARCHAR(15)  UNIQUE\n);\n\n-- Add UNIQUE to existing column\nALTER TABLE users ADD CONSTRAINT UNIQUE(email);\n\nNOT NULL\n\nPrevents a column from accepting NULL (empty/missing) values. Forces data to always be provided.\n\nCREATE TABLE products (\n  product_id INT NOT NULL,\n  name       VARCHAR(100) NOT NULL,\n  price      DECIMAL(8,2)  -- nullable (optional)\n);\n\nALTER TABLE products MODIFY price DECIMAL(8,2) NOT NULL;\n\nCHECK\n\nValidates that column values satisfy a custom condition before insertion or update.\n\nCREATE TABLE employees (\n  emp_id INT,\n  name   VARCHAR(50),\n  salary DECIMAL(10,2),\n  age    INT,\n  CONSTRAINT chk_salary CHECK (salary > 0),\n  CONSTRAINT chk_age    CHECK (age >= 18)\n);\n\nDEFAULT\n\nAutomatically fills a column with a preset value when no value is given during INSERT.\n\nCREATE TABLE orders (\n  order_id   INT,\n  status     VARCHAR(20) DEFAULT 'Pending',\n  created_at DATETIME    DEFAULT NOW(),\n  qty        INT         DEFAULT 1\n);\n\n-- Insert without specifying status — it auto-fills 'Pending'\nINSERT INTO orders (order_id) VALUES (101);\n\nPRIMARY KEY\n\nUniquely identifies each row. Combines UNIQUE + NOT NULL. Every table should have exactly one primary key.\n\nCREATE TABLE students (\n  student_id INT PRIMARY KEY,\n  name       VARCHAR(50) NOT NULL\n);\n\n-- Or define after columns:\nCREATE TABLE students (\n  student_id INT,\n  name       VARCHAR(50),\n  PRIMARY KEY(student_id)\n);\n\nAUTO_INCREMENT\n\nAutomatically generates a unique incrementing number for a column (usually the primary key). No need to manually insert IDs.\n\nCREATE TABLE students (\n  student_id INT AUTO_INCREMENT PRIMARY KEY,\n  name       VARCHAR(50)\n);\n\nINSERT INTO students (name) VALUES ('Arjun');   -- ID = 1\nINSERT INTO students (name) VALUES ('Priya');   -- ID = 2\n\nALTER TABLE students AUTO_INCREMENT = 1000; -- start from 1000\n\nFOREIGN KEY\n\nLinks a column in one table to the PRIMARY KEY in another table. Enforces referential integrity — you can't insert a foreign key value\nthat doesn't exist in the parent table.\n\nCREATE TABLE courses (\n  course_id INT AUTO_INCREMENT PRIMARY KEY,\n  name      VARCHAR(100)\n);\n\nCREATE TABLE enrollments (\n  enroll_id  INT AUTO_INCREMENT PRIMARY KEY,\n  student_id INT,\n  course_id  INT,\n  FOREIGN KEY (student_id) REFERENCES students(student_id),\n  FOREIGN KEY (course_id)  REFERENCES courses(course_id)\n);\nForeign keys prevent orphan records — e.g., you cannot enroll in a course that doesn't exist.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UNIQUE\n\nEnsures all values in a column are different. Multiple UNIQUE columns are allowed per table (unlike PRIMARY KEY).\n\nCREATE TABLE users (\n  user_id INT,\n  email   VARCHAR(100) UNIQUE,\n  phone   VARCHAR(15)  UNIQUE\n);\n\n-- Add UNIQUE to existing column\nALTER TABLE users ADD CONSTRAINT UNIQUE(email);\n\nNOT NULL\n\nPrevents a column from accepting NULL (empty/missing) values. Forces data to always be provided.\n\nCREATE TABLE products (\n  product_id INT NOT NULL,\n  name       VARCHAR(100) NOT NULL,\n  price      DECIMAL(8,2)  -- nullable (optional)\n);\n\nALTER TABLE products MODIFY price DECIMAL(8,2) NOT NULL;\n\nCHECK\n\nValidates that column values satisfy a custom condition before insertion or update.\n\nCREATE TABLE employees (\n  emp_id INT,\n  name   VARCHAR(50),\n  salary DECIMAL(10,2),\n  age    INT,\n  CONSTRAINT chk_salary CHECK (salary > 0),\n  CONSTRAINT chk_age    CHECK (age >= 18)\n);\n\nDEFAULT\n\nAutomatically fills a column with a preset value when no value is given during INSERT.\n\nCREATE TABLE orders (\n  order_id   INT,\n  status     VARCHAR(20) DEFAULT 'Pending',\n  created_at DATETIME    DEFAULT NOW(),\n  qty        INT         DEFAULT 1\n);\n\n-- Insert without specifying status — it auto-fills 'Pending'\nINSERT INTO orders (order_id) VALUES (101);\n\nPRIMARY KEY\n\nUniquely identifies each row. Combines UNIQUE + NOT NULL. Every table should have exactly one primary key.\n\nCREATE TABLE students (\n  student_id INT PRIMARY KEY,\n  name       VARCHAR(50) NOT NULL\n);\n\n-- Or define after columns:\nCREATE TABLE students (\n  student_id INT,\n  name       VARCHAR(50),\n  PRIMARY KEY(student_id)\n);\n\nAUTO_INCREMENT\n\nAutomatically generates a unique incrementing number for a column (usually the primary key). No need to manually insert IDs.\n\nCREATE TABLE students (\n  student_id INT AUTO_INCREMENT PRIMARY KEY,\n  name       VARCHAR(50)\n);\n\nINSERT INTO students (name) VALUES ('Arjun');   -- ID = 1\nINSERT INTO students (name) VALUES ('Priya');   -- ID = 2\n\nALTER TABLE students AUTO_INCREMENT = 1000; -- start from 1000\n\nFOREIGN KEY\n\nLinks a column in one table to the PRIMARY KEY in another table. Enforces referential integrity — you can't insert a foreign key value that doesn't exist in the parent table.\n\nCREATE TABLE courses (\n  course_id INT AUTO_INCREMENT PRIMARY KEY,\n  name      VARCHAR(100)\n);\n\nCREATE TABLE enrollments (\n  enroll_id  INT AUTO_INCREMENT PRIMARY KEY,\n  student_id INT,\n  course_id  INT,\n  FOREIGN KEY (student_id) REFERENCES students(student_id),\n  FOREIGN KEY (course_id)  REFERENCES courses(course_id)\n);\nForeign keys prevent orphan records — e.g., you cannot enroll in a course that doesn't exist.",
      "autoResize": false,
      "lineHeight": 1.25
    },
