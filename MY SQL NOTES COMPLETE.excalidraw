      "updated": 1775457527240,
      "link": null,
      "locked": false,
      "text": "SELECT name FROM students\nUNION\nSELECT name FROM teachers;          -- removes duplicates\n\nSELECT name FROM students\nUNION ALL\nSELECT name FROM teachers;          -- keeps duplicates",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT name FROM students\nUNION\nSELECT name FROM teachers;          -- removes duplicates\n\nSELECT name FROM students\nUNION ALL\nSELECT name FROM teachers;          -- keeps duplicates",
      "autoResize": true,
      "lineHeight": 1.25
    },
