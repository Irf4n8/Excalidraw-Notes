      "type": "text",
      "x": -16253.86656923285,
      "y": 21231.23438262003,
      "width": 1410.7995605468757,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
