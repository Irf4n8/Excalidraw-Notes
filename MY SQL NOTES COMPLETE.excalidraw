      "link": null,
      "locked": false,
      "text": "SELECT\n\nRetrieve data from a table. The most-used SQL command.\n\nSELECT * FROM students;                  -- all columns\nSELECT name, gpa FROM students;          -- specific columns\nSELECT name AS student_name FROM students; -- alias\nSELECT DISTINCT name FROM students;      -- no duplicates",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT\n\nRetrieve data from a table. The most-used SQL command.\n\nSELECT * FROM students;                  -- all columns\nSELECT name, gpa FROM students;          -- specific columns\nSELECT name AS student_name FROM students; -- alias\nSELECT DISTINCT name FROM students;      -- no duplicates",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "qD63TNxdnZggEbraZWNJa",
      "type": "text",
      "x": -16422.17597678495,
      "y": 9464.067715953357,
      "width": 1515.0850423177087,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
