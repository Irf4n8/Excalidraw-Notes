      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457910232,
      "link": null,
      "locked": false,
      "text": "Use WHERE before grouping, HAVING after\ngrouping.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Use WHERE before grouping, HAVING after grouping.",
      "autoResize": false,
      "lineHeight": 1.25
    },
