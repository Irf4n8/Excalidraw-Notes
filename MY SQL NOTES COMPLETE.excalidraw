      "isDeleted": false,
      "boundElements": null,
      "updated": 1775458017936,
      "link": null,
      "locked": false,
      "text": "CASCADE is common in apps. SET NULL is\nuseful when the child record should still exist\nwithout the parent.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CASCADE is common in apps. SET NULL is useful when the child record should still exist without the parent.",
      "autoResize": false,
      "lineHeight": 1.25
    },
