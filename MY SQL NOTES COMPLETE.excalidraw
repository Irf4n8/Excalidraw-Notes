      "link": null,
      "locked": false,
      "text": "3. RIGHT JOIN",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. RIGHT JOIN",
      "autoResize": true,
