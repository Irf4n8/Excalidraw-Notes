    },
    {
      "id": "OkojkBYdse7avswmz4OTC",
      "type": "text",
      "x": -12220.766715717222,
      "y": 4268.258192143836,
      "width": 1283.7427106584823,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bME",
      "roundness": null,
      "seed": 912718637,
      "version": 224,
      "versionNonce": 1052549709,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775373893844,
      "link": null,
      "locked": false,
      "text": "-- Aggregate functions\nSELECT COUNT(*) FROM students;\nSELECT AVG(gpa) FROM students;\nSELECT MAX(gpa), MIN(gpa) FROM students;\nSELECT SUM(salary) FROM employees;\nSELECT CONCAT(first_name,' ',last_name) AS full_name FROM emp;\nSELECT UPPER(name), LOWER(name) FROM students;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-- Aggregate functions\nSELECT COUNT(*) FROM students;\nSELECT AVG(gpa) FROM students;\nSELECT MAX(gpa), MIN(gpa) FROM students;\nSELECT SUM(salary) FROM employees;\nSELECT CONCAT(first_name,' ',last_name) AS full_name FROM emp;\nSELECT UPPER(name), LOWER(name) FROM students;",
      "autoResize": false,
      "lineHeight": 1.25
    },
