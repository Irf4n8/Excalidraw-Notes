    },
    {
      "id": "x4lPhclUNTUEcpDp_y6iZ",
      "type": "text",
      "x": -16228.815370909278,
      "y": 16164.901049286695,
      "width": 1190.6971638997384,
      "height": 810,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bLU",
      "roundness": null,
      "seed": 46452803,
      "version": 195,
      "versionNonce": 954433123,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775373004830,
      "link": null,
      "locked": false,
      "text": "JOINs\n\nCombine rows from two or more tables based on a related\ncolumn.\n\n-- INNER JOIN: only matching rows\nSELECT s.name, c.name\nFROM students s\nINNER JOIN enrollments e ON s.student_id = e.student_id\nINNER JOIN courses c ON e.course_id = c.course_id;\n\n-- LEFT JOIN: all rows from left table + matches from right\nSELECT s.name, e.course_id\nFROM students s\nLEFT JOIN enrollments e ON s.student_id = e.student_id;\n\n-- RIGHT JOIN: all rows from right table\n-- FULL OUTER JOIN: all rows from both tables",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "JOINs\n\nCombine rows from two or more tables based on a related column.\n\n-- INNER JOIN: only matching rows\nSELECT s.name, c.name\nFROM students s\nINNER JOIN enrollments e ON s.student_id = e.student_id\nINNER JOIN courses c ON e.course_id = c.course_id;\n\n-- LEFT JOIN: all rows from left table + matches from right\nSELECT s.name, e.course_id\nFROM students s\nLEFT JOIN enrollments e ON s.student_id = e.student_id;\n\n-- RIGHT JOIN: all rows from right table\n-- FULL OUTER JOIN: all rows from both tables",
      "autoResize": false,
      "lineHeight": 1.25
    },
