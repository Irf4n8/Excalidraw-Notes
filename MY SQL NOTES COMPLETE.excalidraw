      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457749472,
      "link": null,
      "locked": false,
      "text": "Views don't store data — they re-run the query each time. Great for hiding sensitive columns.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Views don't store data — they re-run the query each time. Great for hiding sensitive columns.",
      "autoResize": true,
      "lineHeight": 1.25
    },
