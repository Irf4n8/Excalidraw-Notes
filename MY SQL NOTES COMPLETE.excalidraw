    },
    {
      "id": "ACYce5jsRKDbKeyMinN1o",
      "type": "text",
      "x": -12167.331057126266,
      "y": 13111.906426049327,
      "width": 1046.9103800455728,
      "height": 630,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNg",
      "roundness": null,
      "seed": 2092553674,
      "version": 269,
      "versionNonce": 1899197782,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775458091022,
      "link": null,
      "locked": false,
      "text": "DELIMITER $$\nCREATE TRIGGER before_salary_update\nBEFORE UPDATE ON employees\nFOR EACH ROW\nBEGIN\n  IF NEW.salary < 0 THEN\n    SIGNAL SQLSTATE '45000'\n    SET MESSAGE_TEXT = 'Salary cannot be negative';\n  END IF;\nEND$$\nDELIMITER ;\n\nSHOW TRIGGERS;\nDROP TRIGGER before_salary_update;",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DELIMITER $$\nCREATE TRIGGER before_salary_update\nBEFORE UPDATE ON employees\nFOR EACH ROW\nBEGIN\n  IF NEW.salary < 0 THEN\n    SIGNAL SQLSTATE '45000'\n    SET MESSAGE_TEXT = 'Salary cannot be negative';\n  END IF;\nEND$$\nDELIMITER ;\n\nSHOW TRIGGERS;\nDROP TRIGGER before_salary_update;",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "NxG4-MpqKP17372Ftlhb9",
      "type": "text",
      "x": -10869.709200436811,
