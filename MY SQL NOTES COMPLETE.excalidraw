      "index": "bM9",
      "roundness": null,
      "seed": 1565166595,
      "version": 231,
      "versionNonce": 1695052941,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775373765289,
      "link": null,
      "locked": false,
      "text": "Step 3: Performing the Self Join\nSELECT a.name AS employee, b.name AS manager\nFROM employees a, employees b\nWHERE a.manager_id = b.employee_id;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 3: Performing the Self Join\nSELECT a.name AS employee, b.name AS manager\nFROM employees a, employees b\nWHERE a.manager_id = b.employee_id;",
      "autoResize": false,
      "lineHeight": 1.25
    },
