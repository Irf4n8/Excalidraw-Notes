    {
      "id": "qwH6DxNNU8mC0Zb0Hdkbo",
      "type": "text",
      "x": -12161.37586710348,
      "y": 9826.906426049338,
      "width": 950.3994140625,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
