    },
    {
      "id": "cCfFX2ybcFp2qpvV7_ql3",
      "type": "text",
      "x": -16091.466544818788,
      "y": 18341.73438262003,
      "width": 1413.9995117187493,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bLt",
      "roundness": null,
      "seed": 1241821507,
      "version": 184,
      "versionNonce": 959662605,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775373520142,
      "link": null,
      "locked": false,
      "text": "It Returns all the rows from the right table and the matched rows from\nthe left table. NULL values will be returned for columns from the left\ntable when there are no matches.\n\nSELECT employees.name, departments.department_name\nFROM employees\nRIGHT JOIN departments\nON employees.department_id = departments.department_id;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It Returns all the rows from the right table and the matched rows from the left table. NULL values will be returned for columns from the left table when there are no matches.\n\nSELECT employees.name, departments.department_name\nFROM employees\nRIGHT JOIN departments\nON employees.department_id = departments.department_id;",
      "autoResize": false,
      "lineHeight": 1.25
    },
