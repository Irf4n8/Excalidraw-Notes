      "updated": 1775458047273,
      "link": null,
      "locked": false,
      "text": "DELIMITER $$\nCREATE PROCEDURE GetStudentsByGPA(IN min_gpa DECIMAL(3,2))\nBEGIN\n  SELECT name, gpa FROM students WHERE gpa >= min_gpa;\nEND$$\nDELIMITER ;\n\nCALL GetStudentsByGPA(3.5);\nDROP PROCEDURE GetStudentsByGPA;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DELIMITER $$\nCREATE PROCEDURE GetStudentsByGPA(IN min_gpa DECIMAL(3,2))\nBEGIN\n  SELECT name, gpa FROM students WHERE gpa >= min_gpa;\nEND$$\nDELIMITER ;\n\nCALL GetStudentsByGPA(3.5);\nDROP PROCEDURE GetStudentsByGPA;",
      "autoResize": true,
      "lineHeight": 1.25
    },
