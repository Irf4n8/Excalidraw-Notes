    {
      "id": "WgRw2ViTbUx00TrnbsXin",
      "type": "text",
      "x": -15376.800122292743,
      "y": 13959.901049286691,
      "width": 354.52789306640625,
      "height": 45,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
