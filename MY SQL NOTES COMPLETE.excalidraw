      "boundElements": [],
      "updated": 1775373424722,
      "link": null,
      "locked": false,
      "text": "It returns all records from the Left table and matched records from the\nRight table. If there is no match, then NULL values are returned for\nRight table columns.\n\nSELECT employees.name, departments.department_name\nFROM employees\nLEFT JOIN departments\nON employees.department_id = departments.department_id;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It returns all records from the Left table and matched records from the Right table. If there is no match, then NULL values are returned for Right table columns.\n\nSELECT employees.name, departments.department_name\nFROM employees\nLEFT JOIN departments\nON employees.department_id = departments.department_id;",
      "autoResize": false,
      "lineHeight": 1.25
    },
