      "updated": 1775366984799,
      "link": null,
      "locked": false,
      "text": "UPDATE & DELETE\n\nModify or remove existing rows. Always use WHERE to target specific rows.\n\nUPDATE students SET gpa = 3.9 WHERE student_id = 1;\n\nDELETE FROM students WHERE student_id = 3;\nNever run UPDATE or DELETE without a WHERE clause — it will affect ALL rows!",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UPDATE & DELETE\n\nModify or remove existing rows. Always use WHERE to target specific rows.\n\nUPDATE students SET gpa = 3.9 WHERE student_id = 1;\n\nDELETE FROM students WHERE student_id = 3;\nNever run UPDATE or DELETE without a WHERE clause — it will affect ALL rows!",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "1eY8-AV-5lKFJPokScLCH",
      "type": "text",
      "x": -16432.305361143677,
      "y": 9885.734382620021,
      "width": 2372.0104777018223,
      "height": 585,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
