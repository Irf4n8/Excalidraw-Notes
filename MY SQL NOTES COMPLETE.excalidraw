    {
      "id": "ICZSRSARDJvfeyIHeo1TD",
      "type": "text",
      "x": -16141.566550922304,
      "y": 19769.73438262003,
      "width": 1222.199523925781,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bLz",
      "roundness": null,
      "seed": 1048732771,
      "version": 145,
      "versionNonce": 1702120515,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775373626435,
      "link": null,
      "locked": false,
      "text": "It Returns the Cartesian product of two tables. Matches every\nrow of one table with every row of another table.\n\nSELECT employees.name, departments.department_name\nFROM employees\nCROSS JOIN departments;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It Returns the Cartesian product of two tables. Matches every row of one table with every row of another table.\n\nSELECT employees.name, departments.department_name\nFROM employees\nCROSS JOIN departments;",
      "autoResize": false,
      "lineHeight": 1.25
    },
