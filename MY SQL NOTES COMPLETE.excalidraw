      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457970162,
      "link": null,
      "locked": false,
      "text": "SELECT dept, SUM(salary) AS total_salary\nFROM employees\nGROUP BY dept WITH ROLLUP;\n-- Adds a NULL row at the end = grand\ntotal",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT dept, SUM(salary) AS total_salary\nFROM employees\nGROUP BY dept WITH ROLLUP;\n-- Adds a NULL row at the end = grand total",
      "autoResize": false,
      "lineHeight": 1.25
    },
