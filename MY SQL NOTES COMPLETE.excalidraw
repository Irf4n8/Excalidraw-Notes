      "boundElements": [],
      "updated": 1775373147911,
      "link": null,
      "locked": false,
      "text": "\nIt Returns records that have matching values in both\ntables.\n\nSELECT employees.name, departments.department_name\nFROM employees\nINNER JOIN departments\nON employees.department_id =\ndepartments.department_id;",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nIt Returns records that have matching values in both tables.\n\nSELECT employees.name, departments.department_name\nFROM employees\nINNER JOIN departments\nON employees.department_id = departments.department_id;",
      "autoResize": false,
      "lineHeight": 1.25
    },
