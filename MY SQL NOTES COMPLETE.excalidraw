      "versionNonce": 946697738,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775457574775,
      "link": null,
      "locked": false,
      "text": "A table joins with itself. Useful for hierarchical data like employees and their\nmanagers.\n\n-- employees table: emp_id, name, manager_id\nSELECT\n  e.name     AS employee,\n  m.name     AS manager\nFROM employees e\nINNER JOIN employees m ON e.manager_id = m.emp_id;\nUse aliases (e and m) to distinguish the two copies of the same table.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A table joins with itself. Useful for hierarchical data like employees and their managers.\n\n-- employees table: emp_id, name, manager_id\nSELECT\n  e.name     AS employee,\n  m.name     AS manager\nFROM employees e\nINNER JOIN employees m ON e.manager_id = m.emp_id;\nUse aliases (e and m) to distinguish the two copies of the same table.",
      "autoResize": false,
      "lineHeight": 1.25
    },
