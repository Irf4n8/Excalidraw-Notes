      "updated": 1775458109081,
      "link": null,
      "locked": false,
      "text": "Use NEW.column for the updated value,\nOLD.column for the previous value inside\ntriggers.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Use NEW.column for the updated value, OLD.column for the previous value inside triggers.",
      "autoResize": false,
      "lineHeight": 1.25
    },
