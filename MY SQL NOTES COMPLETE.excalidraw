      "link": null,
      "locked": false,
      "text": "Defines what happens to child rows when a parent row (referenced by foreign key) is deleted.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Defines what happens to child rows when a parent row (referenced by foreign key) is deleted.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "5PtCjrRuoxAwlmWg9z_o9",
      "type": "text",
      "x": -12179.709200436811,
      "y": 11776.90642604933,
      "width": 1148.3992919921875,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNH",
      "roundness": null,
      "seed": 1655389782,
      "version": 5,
      "versionNonce": 1074200138,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775458006441,
      "link": null,
      "locked": false,
      "text": "-- Options: CASCADE, SET NULL, RESTRICT, SET DEFAULT\nFOREIGN KEY (student_id)\n  REFERENCES students(student_id)\n  ON DELETE CASCADE;    -- delete child rows too\n\n  ON DELETE SET NULL;   -- set FK column to NULL\n\n  ON DELETE RESTRICT;   -- block parent deletion (default)",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-- Options: CASCADE, SET NULL, RESTRICT, SET DEFAULT\nFOREIGN KEY (student_id)\n  REFERENCES students(student_id)\n  ON DELETE CASCADE;    -- delete child rows too\n\n  ON DELETE SET NULL;   -- set FK column to NULL\n\n  ON DELETE RESTRICT;   -- block parent deletion (default)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "8jv-zKhXmOqdzWKCR3PqC",
      "type": "text",
      "x": -10869.242301836552,
