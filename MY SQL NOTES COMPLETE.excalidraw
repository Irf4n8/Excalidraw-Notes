      "text": "Built-in aggregate and string functions for\ncalculations and data manipulation.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Built-in aggregate and string functions for calculations and data manipulation.",
