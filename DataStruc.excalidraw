    {
      "id": "hE3h97-LunemqTPvAAiCC",
      "type": "text",
      "x": -7296.17094473973,
      "y": -1439.6502264958383,
      "width": 763.0556640625,
      "height": 2240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bH8",
      "roundness": null,
      "seed": 1164534737,
      "version": 490,
      "versionNonce": 936916646,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772354493459,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n\n    vector<int> v = {1,2,3,4,5};\n\n    // Normal indexing\n    for (int i = 0; i < v.size(); i++) {\n        cout << v[i] << \" \";\n    }\n    cout << endl;\n\n    cout << v.front() << endl;\n    cout << v.back() << endl;\n\n    // Using iterators\n    for (vector<int>::iterator it = v.begin(); it != v.end();\nit++) {\n        cout << *it << \" \";\n    }\n    cout << endl;\n\n    // Range based loop\n    for (auto i : v) {\n        cout << i << \" \";\n    }\n    cout << endl;\n\n    // Reverse iteration\n    for (auto it = v.rbegin(); it != v.rend(); it++) {\n        cout << *it << \" \";\n    }\n    cout << endl;\n\n    // Insert\n    v.insert(v.begin() + 1, 69);\n\n    for (auto i : v) {\n        cout << i << \" \";\n    }\n    cout << endl;\n\n    // Clear\n    v.clear();\n    cout << \"Size after clear: \" << v.size() << endl;\n\n    // Swap\n    vector<int> v1 = {1,2,3};\n    vector<int> v2 = {4,5,6};\n\n    swap(v1, v2);\n\n    for (int i : v1) {\n        cout << i << \" \";\n    }\n    cout<<endl;\n    for (int i : v2) {\n        cout << i << \" \";\n    }\n\n\n    return 0;\n}",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n\n    vector<int> v = {1,2,3,4,5};\n\n    // Normal indexing\n    for (int i = 0; i < v.size(); i++) {\n        cout << v[i] << \" \";\n    }\n    cout << endl;\n\n    cout << v.front() << endl;\n    cout << v.back() << endl;\n\n    // Using iterators\n    for (vector<int>::iterator it = v.begin(); it != v.end(); it++) {\n        cout << *it << \" \";\n    }\n    cout << endl;\n\n    // Range based loop\n    for (auto i : v) {\n        cout << i << \" \";\n    }\n    cout << endl;\n\n    // Reverse iteration\n    for (auto it = v.rbegin(); it != v.rend(); it++) {\n        cout << *it << \" \";\n    }\n    cout << endl;\n\n    // Insert\n    v.insert(v.begin() + 1, 69);\n\n    for (auto i : v) {\n        cout << i << \" \";\n    }\n    cout << endl;\n\n    // Clear\n    v.clear();\n    cout << \"Size after clear: \" << v.size() << endl;\n\n    // Swap\n    vector<int> v1 = {1,2,3};\n    vector<int> v2 = {4,5,6};\n\n    swap(v1, v2);\n\n    for (int i : v1) {\n        cout << i << \" \";\n    }\n    cout<<endl;\n    for (int i : v2) {\n        cout << i << \" \";\n    }\n\n\n    return 0;\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
