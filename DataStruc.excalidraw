    {
      "id": "9XhICs8A_hnNOeK4HL8cS",
      "type": "text",
      "x": -9936.651817575636,
      "y": -1594.4502608933417,
      "width": 783.899658203125,
      "height": 990,
      "angle": 0,
      "strokeColor": "#6741d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bHk",
