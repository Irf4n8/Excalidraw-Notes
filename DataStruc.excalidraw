    {
      "id": "T-aUcs-fh_c3I9HvP67vK",
      "type": "text",
      "x": -4221.551760424507,
      "y": -714.6672498237784,
      "width": 516.1517944335938,
      "height": 1260,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bJ6",
      "roundness": null,
      "seed": 2008742510,
      "version": 55,
      "versionNonce": 319401778,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772594520564,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n\n    stack<int> stack1;\n    stack1.push(1);\n    stack1.push(2);\n    stack1.push(3);\n    stack1.push(4);\n    stack1.push(5);\n\n    stack<int> stack2;\n\n    // Pushing\n    stack2.push(1); // 1\n    stack2.push(2); // 2 1\n    stack2.push(3); // 3 2 1\n\n    cout << stack2.top() << endl; // 3\n\n    // Popping\n    stack2.pop(); // removes 3\n    cout << stack2.top() << endl; // 2\n\n    stack2.pop(); // removes 2\n    cout << stack2.top() << endl; // 1\n\n    // Swapping\n    stack1.swap(stack2);\n\n    cout << stack2.top() << endl; // 5\n    cout << stack1.top() << endl; // 1\n    cout<< stack1.size()<<endl;\n    cout<< stack2.size()<<endl;\n}",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n\n    stack<int> stack1;\n    stack1.push(1);\n    stack1.push(2);\n    stack1.push(3);\n    stack1.push(4);\n    stack1.push(5);\n\n    stack<int> stack2;\n\n    // Pushing\n    stack2.push(1); // 1\n    stack2.push(2); // 2 1\n    stack2.push(3); // 3 2 1\n\n    cout << stack2.top() << endl; // 3\n\n    // Popping\n    stack2.pop(); // removes 3\n    cout << stack2.top() << endl; // 2\n\n    stack2.pop(); // removes 2\n    cout << stack2.top() << endl; // 1\n\n    // Swapping\n    stack1.swap(stack2);\n\n    cout << stack2.top() << endl; // 5\n    cout << stack1.top() << endl; // 1\n    cout<< stack1.size()<<endl;\n    cout<< stack2.size()<<endl;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
