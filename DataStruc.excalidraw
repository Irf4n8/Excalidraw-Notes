      "seed": 1844723430,
      "version": 104,
      "versionNonce": 739848422,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772354445821,
      "link": null,
      "locked": false,
      "text": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n    pair<int,int>sample={1,2};\n    pair<int,char>sample2;//declared another\npair\n    cout<<sample.first<<'\\n';\n    cout<<sample.second<<'\\n';\n    sample2.first=69;\n    sample2.second='I';\n    cout<<sample2.first<<'\\n';\n    cout<<sample2.second<<'\\n';\n    pair<int,char>sample3=make_pair(1,'R');\n    cout<<sample3.first<<'\\n';\n    cout<<sample3.second<<'\\n';\n    //pair inside pair\n    pair<pair<int,char>,char> dpair={{1,'A'},'b'};\n    cout << dpair.first.first<<'\\n'; \n    cout << dpair.first.second<<'\\n'; \n    cout << dpair.second<<'\\n';\n}",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n    pair<int,int>sample={1,2};\n    pair<int,char>sample2;//declared another pair\n    cout<<sample.first<<'\\n';\n    cout<<sample.second<<'\\n';\n    sample2.first=69;\n    sample2.second='I';\n    cout<<sample2.first<<'\\n';\n    cout<<sample2.second<<'\\n';\n    pair<int,char>sample3=make_pair(1,'R');\n    cout<<sample3.first<<'\\n';\n    cout<<sample3.second<<'\\n';\n    //pair inside pair\n    pair<pair<int,char>,char> dpair={{1,'A'},'b'};\n    cout << dpair.first.first<<'\\n'; \n    cout << dpair.first.second<<'\\n'; \n    cout << dpair.second<<'\\n';\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
